            "documents": [
                {
                    "_docId": "msg_001",
                    "message": "Hello! I'm Velmora AI, your relationship wellness assistant. How can I help you today?",
                    "isUser": false,
                    "timestamp": {
                        "__type": "Timestamp",
                        "seconds": 1709596800,
                        "nanoseconds": 0
                    }
                },
                {
                    "_docId": "msg_002",
                    "message": "Hi! Can you tell me about the benefits of Kegel exercises?",
                    "isUser": true,
                    "timestamp": {
                        "__type": "Timestamp",
                        "seconds": 1709596860,
                        "nanoseconds": 0
                    }
                },
                {
                    "_docId": "msg_003",
                    "message": "Kegel exercises strengthen your pelvic floor muscles, which can improve bladder control, enhance sexual health, and support core stability. Our app offers three levels: Beginner (5 min), Intermediate (8 min), and Advanced (12 min). Would you like to start with the Beginner routine?",
                    "isUser": false,
                    "timestamp": {
                        "__type": "Timestamp",
                        "seconds": 1709596920,
                        "nanoseconds": 0
                    }
                },
                {
                    "_docId": "msg_004",
                    "message": "What games do you have for couples?",
                    "isUser": true,
                    "timestamp": {
                        "__type": "Timestamp",
                        "seconds": 1709683200,
                        "nanoseconds": 0
                    }
                },
                {
                    "_docId": "msg_005",
                    "message": "We have 3 engaging games:\n\n1. **Truth or Truth** (Free) - Answer truthful questions to deepen your connection\n2. **Love Language Quiz** (Premium) - Discover your love languages\n3. **Reflection & Discussion** (Premium) - Meaningful conversations\n\nThe Truth or Truth game is free to try! Premium games unlock with a subscription starting at $3.99/month.",
                    "isUser": false,
                    "timestamp": {
                        "__type": "Timestamp",
                        "seconds": 1709683260,
                        "nanoseconds": 0
                    }
                },
                {
                    "_docId": "msg_006",
                    "message": "How does the free trial work?",
                    "isUser": true,
                    "timestamp": {
                        "__type": "Timestamp",
                        "seconds": 1710115200,
                        "nanoseconds": 0
                    }
                },
                {
                    "_docId": "msg_007",
                    "message": "Great question! Our free trial gives you:\n\n✅ 3 AI chat messages per day\n✅ Access to Truth or Truth game\n✅ Basic Kegel exercises\n\nUpgrade to Premium for:\n🌟 Unlimited AI chats\n🌟 All premium games\n🌟 Advanced Kegel routines\n🌟 Priority support\n\nPlans: Monthly $3.99, Quarterly $9.99, Yearly $29.99",
                    "isUser": false,
                    "timestamp": {
                        "__type": "Timestamp",
                        "seconds": 1710115260,
                        "nanoseconds": 0
                    }
                }
            ]
        },
